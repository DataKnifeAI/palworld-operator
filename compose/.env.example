# Copy to .env and edit before `make compose-up`:
#   cp compose/.env.example compose/.env

# Official Pocketpair image (pin a tag when you want a fixed game version)
PALSERVER_IMAGE=ghcr.io/pocketpairjp/palserver:latest

# Host ports (container always listens on 8211 / 27015 / 8212 / 25575)
GAME_PORT=8211
QUERY_PORT=27015
REST_PORT=8212
RCON_PORT=25575

# Resource caps for a minimal PC / laptop (raise if the container is OOM-killed)
MEM_LIMIT=6g
CPU_LIMIT=4.0
SHM_SIZE=1gb

# Seeded into Saved/Config/LinuxServer/PalWorldSettings.ini on first start only
# (existing INI is never overwritten — edit the file or delete it to re-seed)
SERVER_NAME="Palworld Local"
SERVER_DESCRIPTION="Local PC compose — no Kubernetes"
MAX_PLAYERS=4
SERVER_PASSWORD="change-me-join"
ADMIN_PASSWORD="change-me-admin"
RCON_ENABLED=True
REST_API_ENABLED=True
CROSSPLAY_PLATFORMS="(Steam,Xbox,PS5,Mac)"
